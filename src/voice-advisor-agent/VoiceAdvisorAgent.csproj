<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>VoiceAdvisorAgent</RootNamespace>
    <AzureCosmosDisableNewtonsoftJsonCheck>true</AzureCosmosDisableNewtonsoftJsonCheck>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Azure.AI.Inference" Version="13.4.0-preview.1.26279.43" />
    <PackageReference Include="Azure.AI.Extensions.OpenAI" Version="2.1.0-beta.2" />
    <PackageReference Include="Azure.AI.Projects" Version="2.1.0-beta.2" />
    <PackageReference Include="Azure.AI.Projects.Agents" Version="2.1.0-beta.2" />
    <PackageReference Include="Azure.AI.VoiceLive" Version="1.0.0" />
    <PackageReference Include="Aspire.Microsoft.Azure.Cosmos" Version="13.4.0" />
    <PackageReference Include="Microsoft.Agents.AI.Foundry" Version="1.6.2-preview.260521.1" />
    <PackageReference Include="Microsoft.Agents.AI.Foundry.Hosting" Version="1.6.2-preview.260521.1" />
    <PackageReference Include="Microsoft.Azure.Cosmos" Version="3.59.0" />

    <!-- Microsoft Agent Framework (MAF) for A2A agent invocation -->
    <PackageReference Include="Microsoft.Agents.AI" Version="1.6.2" />
    <PackageReference Include="Microsoft.Agents.AI.A2A" Version="1.6.2-preview.260521.1" />
    <PackageReference Include="Microsoft.Agents.AI.Hosting" Version="1.6.2-preview.260521.1" />
    <PackageReference Include="Microsoft.Agents.AI.Hosting.A2A.AspNetCore" Version="1.6.2-preview.260521.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\service-defaults\service-defaults.csproj" />
    <ProjectReference Include="..\shared-services\SharedServices.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Prompts\*.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
